# Copy this file to .env and fill in real values on each machine/server.
# Never commit .env.
SOLANA_PRIVATE_KEY=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
JUP_API_KEY=
JUP_API_KEYS=
# Dynamic sizing: require $0.10 net, then choose the eligible quote with the
# highest capital efficiency (net return bps), not the largest dollar result.
MIN_TRADE_SIZE_USD=1000
MIN_NET_PROFIT_USD=0.10
MIN_NET_RETURN_BPS=0
# USDG reserves refill after falling below $2,000. The extra $1 ensures
# a 5,000 reserve uses a minimum candidate of 3,001, leaving 1,999.
USDG_REFILL_THRESHOLD_USD=2000
USDG_REFILL_BUFFER_USD=1
DEFAULT_EXECUTION_COST_USD=0.005
EXECUTION_COST_SAFETY_MULTIPLIER=1.25
QUOTE_SAMPLE_DELAY_SECONDS=0.15
PORT=25284

# Optional: defaults to ./bot_state.json.
# BOT_STATE_FILE=/absolute/path/to/bot_state.json
