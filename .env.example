# Copy this file to .env and fill in real values on each machine/server.
# Never commit .env.
SOLANA_PRIVATE_KEY=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
JUP_API_KEY=
JUP_API_KEYS=
# Dynamic sizing: require $0.10 net, then choose the eligible size with the
# highest absolute net dollar profit within the first profitable route.
MIN_TRADE_SIZE_USD=1000
MIN_NET_PROFIT_USD=0.10
LOW_RESERVE_MIN_NET_PROFIT_USD=0.05
USDG_LOW_RESERVE_THRESHOLD=7500
PYUSD_LOW_RESERVE_THRESHOLD=0.10
# Optional eligibility filter only; this does not rank passing quotes.
MIN_NET_RETURN_BPS=0
JUPITER_ENTRY_MAX_RETRIES=5
# Stable-first USDG routes drain the Stable.com USDG reserve rather than
# selecting a trade that merely leaves it near a refill threshold.
# Stable.com requires at least $1.80 USDG after this operation. The safety
# buffer makes the effective default minimum $1.90; keep the maximum below
# $2.00 so the reserve refill trigger can activate.
USDG_DRAIN_MIN_REMAINDER_USD=1.80
USDG_DRAIN_SAFETY_BUFFER_USD=0.10
USDG_MAX_REMAINDER_USD=1.99
DEFAULT_EXECUTION_COST_USD=0.005
EXECUTION_COST_SAFETY_MULTIPLIER=1.25
QUOTE_SAMPLE_DELAY_SECONDS=0.15
# Confirm both sides of each transfer from fresh confirmed WebSocket revisions.
# If no matching event arrives, take one RPC snapshot instead of polling.
WS_CONFIRM_TIMEOUT_SECONDS=12
# Recovery worker: after a failed second leg, it watches the exact stranded
# USDG/PYUSD amount and returns it only when this conservative net profit wins.
# One bps is included both in Jupiter's transaction tolerance and in the
# profitability reserve so a zero-slippage retry is not repeatedly submitted.
RECOVERY_MIN_NET_PROFIT_USD=0.10
RECOVERY_JUP_SLIPPAGE_BPS=1
RECOVERY_EXECUTION_COST_USD=0.01
RECOVERY_QUOTE_INTERVAL_SECONDS=1
# If the exact Jupiter recovery quote cannot clear the threshold, recovery
# submits the Stable.com token->USDC exit immediately and only retries a
# rejected Stable.com request after this short delay.
RECOVERY_STABLE_RETRY_SECONDS=5
# Stable.com's create-order API currently rejects larger single orders.
RECOVERY_STABLE_MAX_AMOUNT_USD=1000000
# Only used if a submitted transaction remains ambiguous after the normal
# WS window and one RPC snapshot. No new trade starts during reconciliation.
SIGNATURE_CHECK_INTERVAL_SECONDS=5
# Solana account notifications can expose a refill before Stable.com's order
# service indexes it. Delay USDG drain quotes after an observed pool increase,
# then back off briefly if the API still reports its old available balance.
STABLE_POOL_REFILL_SYNC_SECONDS=15
STABLE_BACKEND_LAG_RETRY_SECONDS=5
PORT=25284

# Optional: defaults to ./bot_state.json.
# BOT_STATE_FILE=/absolute/path/to/bot_state.json
# RECOVERY_STATE_FILE=/absolute/path/to/recovery_state.json
