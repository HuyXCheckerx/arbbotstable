# Read-only scanning can use WALLET_PUBLIC_KEY without exposing a secret.
# Live execution, init-atas, and create-alt require SOLANA_PRIVATE_KEY.
WALLET_PUBLIC_KEY=
SOLANA_PRIVATE_KEY=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Jupiter Developer Platform key(s). Multiple keys may be comma-separated.
JUP_API_KEY=
JUP_API_KEYS=

# Hard safety boundary. The code refuses any amount outside 10k–100k USDC.
FLASH_LOAN_MIN_USDC=10000
FLASH_LOAN_MAX_USDC=100000
FLASH_LOAN_MARKET=main

# Both switches must be changed before any arbitrage transaction is submitted.
EXECUTION_ENABLED=false
DRY_RUN=true
SIMULATE_DRY_RUN=true

# A successful transaction must guarantee this much after the conservative
# transaction-cost reserve. Expected/optimistic output is never used to qualify.
MIN_NET_PROFIT_USDC=0.10
ESTIMATED_TX_COST_USDC=0.02

# Tight slippage is important because Jupiter's minimum output is the on-chain
# profit guard. Zero minimizes Jupiter-first intermediate-token surplus.
JUPITER_SLIPPAGE_BPS=1
JUPITER_MAX_ACCOUNTS=52
JUPITER_FAST_QUOTES=true
QUOTE_DELAY_MS=100
SCAN_INTERVAL_MS=5000

# Solana permits at most 1.4M CU. The bot first simulates at the maximum and
# rebuilds with the observed usage plus this buffer.
COMPUTE_UNIT_LIMIT=1400000
COMPUTE_UNIT_BUFFER=1.15
COMPUTE_UNIT_PRICE_MICROLAMPORTS=10000

# Stable.com pool protection. The larger USDT reserve matches the original bot.
STABLE_TOKEN_RESERVE_USDC=2
STABLE_USDC_RESERVE_USDC=2
USDT_MIN_USDC_RESERVE_USDC=50000

# Refuse any unanticipated Stable.com native execution fee by default.
MAX_STABLE_NATIVE_FEE_LAMPORTS=0
HTTP_TIMEOUT_MS=10000

# `npm run create-alt` writes the custom table address here automatically.
CUSTOM_ALT_FILE=state/custom-alt.json
CUSTOM_ALT_ADDRESSES=
BOT_STATE_FILE=state/bot-state.json
